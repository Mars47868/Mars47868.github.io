---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TagPill from '../components/TagPill.astro';

const projects = await getCollection('projects');
const sorted = [...projects].sort((a, b) => a.data.order - b.data.order);

const globalTech = ['Python', 'Java', 'Google Apps Script', 'Excel VBA', 'AI 整合', 'Spring Boot'];
---
<BaseLayout title="Mars Chen | AI × 流程自動化">
  <Hero />

  <section class="py-4 border-b border-[var(--aw-color-border)]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <p class="text-base text-[#78716C] dark:text-[#A09590] mb-3">
        用程式解決真實生活中的重複作業——從製造業庫存到醫療診所，從個人投資到內容創作。
      </p>
      <div class="flex flex-wrap gap-2">
        {globalTech.map(t => <TagPill label={t} variant="tech" />)}
      </div>
    </div>
  </section>

  <section id="projects" class="py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#A09590] dark:text-[#6B6460] mb-8">
        作品
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {sorted.map(p => (
          <ProjectCard
            title={p.data.title}
            summary={p.data.summary}
            metric={p.data.metric}
            industry={p.data.industry}
            tech={p.data.tech}
            slug={p.id}
            github={p.data.github}
          />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
