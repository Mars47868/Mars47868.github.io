---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagPill from '../../components/TagPill.astro';
import MetricBlock from '../../components/MetricBlock.astro';
import CTABlock from '../../components/CTABlock.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, summary, industry, tech, metric, github, demo, metricPercentage, metricLabel } = project.data;
---

<BaseLayout title={title} description={summary}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">

    <!-- 標題區：BLUF — metric 數字最大、在最上方 -->
    <header class="mb-8">
      <!-- metric 放大顯示 -->
      <p class="text-3xl md:text-4xl font-bold text-primary mb-3">
        {metric}
      </p>

      <!-- 標題 -->
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-3">
        {title}
      </h1>

      <!-- 一句話摘要 -->
      <p class="text-lg text-gray-600 dark:text-slate-300 mb-6">
        {summary}
      </p>

      <!-- 標籤列 -->
      <div class="flex flex-wrap gap-2 mb-6">
        {industry.map(tag => (
          <TagPill label={tag} variant="industry" />
        ))}
        {tech.map(tag => (
          <TagPill label={tag} variant="tech" />
        ))}
      </div>

      <!-- GitHub / Demo 連結 -->
      {(github || demo) && (
        <div class="flex flex-wrap gap-4 mb-6">
          {github && (
            <a
              href={github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 dark:text-slate-300 hover:text-primary dark:hover:text-white transition-colors"
              aria-label="在 GitHub 上查看原始碼"
            >
              <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z" clip-rule="evenodd" />
              </svg>
              GitHub
            </a>
          )}
          {demo && (
            <a
              href={demo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 dark:text-slate-300 hover:text-primary dark:hover:text-white transition-colors"
              aria-label="查看 Demo"
            >
              <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
              Live Demo
            </a>
          )}
        </div>
      )}

      <!-- 分隔線 -->
      <hr class="border-b border-gray-200 dark:border-slate-700" />
    </header>

    <!-- Markdown 正文 -->
    <div class="prose prose-gray dark:prose-invert max-w-none
      prose-h2:text-xl prose-h2:font-bold prose-h2:mt-10 prose-h2:mb-4
      prose-h2:pb-2 prose-h2:border-b prose-h2:border-gray-200 dark:prose-h2:border-slate-700
      prose-p:leading-relaxed prose-p:my-4
      prose-li:my-1
      prose-a:text-primary prose-a:no-underline hover:prose-a:underline">
      <Content />
    </div>

    <!-- MetricBlock 成效視覺化 -->
    <MetricBlock
      metric={metric}
      percentage={metricPercentage ?? 70}
      label={metricLabel ?? '節省作業時間'}
    />

  </article>

  <!-- 底部 CTABlock -->
  <CTABlock
    heading="有類似需求？找我談談"
    buttonText="聯絡我"
    buttonHref="/contact"
    ariaLabel="前往聯絡頁面"
  />
</BaseLayout>
