---
interface Props {
  heading: string;
  buttonText: string;
  buttonHref: string;
  ariaLabel?: string;
}
const { heading, buttonText, buttonHref, ariaLabel } = Astro.props;
---
<section class="border-t border-[var(--aw-color-border)] py-16 mt-16">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-2xl font-bold text-[#1C1917] dark:text-[#E8E0D8] mb-6">
      {heading}
    </h2>
    <a
      href={buttonHref}
      aria-label={ariaLabel ?? buttonText}
      class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-primary text-white font-semibold hover:bg-secondary transition-colors"
    >
      {buttonText}
    </a>
  </div>
</section>
