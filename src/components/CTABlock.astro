---
interface Props {
  heading: string;
  buttonText: string;
  buttonHref: string;
}
const { heading, buttonText, buttonHref } = Astro.props;
---
<section class="border-t border-gray-200 dark:border-slate-800 py-16 mt-16">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
      {heading}
    </h2>
    <a
      href={buttonHref}
      class="inline-flex items-center justify-center px-6 py-3 rounded-full bg-primary text-white font-semibold hover:bg-secondary transition-colors"
    >
      {buttonText}
    </a>
  </div>
</section>
