---
interface Props {
  metric: string;
  percentage?: number;
  label?: string;
}
const { metric, percentage = 70, label = '節省作業時間' } = Astro.props;
const clampedPct = Math.min(100, Math.max(0, percentage));
---
<div class="bg-[var(--aw-color-bg-page)] dark:bg-[rgba(30,26,22,0.6)] border border-[var(--aw-color-border)] rounded-2xl p-8 text-center my-8">
  <p class="text-xs font-semibold uppercase tracking-widest text-[#78716C] dark:text-[#A09590] mb-4">
    {label}
  </p>
  <div class="w-full bg-[rgba(80,60,40,0.1)] dark:bg-[rgba(255,240,220,0.1)] rounded-full h-2 mb-6 overflow-hidden">
    <div
      role="progressbar"
      aria-valuenow={percentage}
      aria-valuemin={0}
      aria-valuemax={100}
      aria-label={label}
      class="bg-primary h-2 rounded-full transition-all duration-700"
      style={`width: ${clampedPct}%`}
    ></div>
  </div>
  <p class="text-4xl font-bold text-[#1C1917] dark:text-[#E8E0D8]">
    {metric}
  </p>
</div>
